<!-- test: anonymous slot -->
<!-- in:wrapper.html -->
<div><t-slot /></div>
<!-- in -->
<t-extend template="wrapper.html">
<t-define name="">Hello</t-define>
<!-- context -->
<!-- out -->
<div>Hello</div>

<!-- test: named slot -->
<!-- in:layout.html -->
<header><t-slot name="title" /></header><main><t-slot /></main>
<!-- in -->
<t-extend template="layout.html">
<t-define name="title">My Page</t-define>
<t-define name="">Body content</t-define>
<!-- context -->
<!-- out -->
<header>My Page</header><main>Body content</main>

<!-- test: slot with default content -->
<!-- in:layout.html -->
<footer><t-slot name="footer">Default Footer</t-slot></footer>
<!-- in -->
<t-extend template="layout.html">
<t-define name="">main</t-define>
<!-- context -->
<!-- out -->
<footer>Default Footer</footer>

<!-- test: slot default overridden -->
<!-- in:layout.html -->
<footer><t-slot name="footer">Default Footer</t-slot></footer>
<!-- in -->
<t-extend template="layout.html">
<t-define name="footer">Custom Footer</t-define>
<!-- context -->
<!-- out -->
<footer>Custom Footer</footer>

<!-- test: slot with var in content -->
<!-- in:layout.html -->
<h1><t-slot name="title" /></h1>
<!-- in -->
<t-extend template="layout.html">
<t-define name="title"><t-var name="page.title" /></t-define>
<!-- context -->
{"data": {"page": {"title": "Hello World"}}}
<!-- out -->
<h1>Hello World</h1>

<!-- test: self-closing slot with no content renders nothing -->
<!-- in:layout.html -->
[<t-slot name="optional" />]
<!-- in -->
<t-extend template="layout.html">
<t-define name="">main</t-define>
<!-- context -->
<!-- out -->
[]

<!-- test: multiple named slots -->
<!-- in:layout.html -->
<head><t-slot name="head" /></head><nav><t-slot name="nav" /></nav><main><t-slot /></main><footer><t-slot name="footer" /></footer>
<!-- in -->
<t-extend template="layout.html">
<t-define name="head"><title>Test</title></t-define>
<t-define name="nav">nav links</t-define>
<t-define name="">body content</t-define>
<t-define name="footer">copyright</t-define>
<!-- context -->
<!-- out -->
<head><title>Test</title></head><nav>nav links</nav><main>body content</main><footer>copyright</footer>

<!-- test: slot with complex default -->
<!-- in:layout.html -->
<aside><t-slot name="sidebar"><p>Default sidebar</p><ul><li>Item 1</li></ul></t-slot></aside>
<!-- in -->
<t-extend template="layout.html">
<t-define name="">main</t-define>
<!-- context -->
<!-- out -->
<aside><p>Default sidebar</p><ul><li>Item 1</li></ul></aside>

<!-- test: slot inside conditional -->
<!-- in:layout.html -->
<t-if var="show"><t-slot name="extra" /></t-if>
<!-- in -->
<t-extend template="layout.html">
<t-define name="extra">extra content</t-define>
<!-- context -->
{"data": {"show": "yes"}}
<!-- out -->
extra content

<!-- test: slot inside conditional hidden -->
<!-- in:layout.html -->
<t-if var="show"><t-slot name="extra" /></t-if>
<!-- in -->
<t-extend template="layout.html">
<t-define name="extra">extra content</t-define>
<!-- context -->
<!-- out -->
