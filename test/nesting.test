<!-- test: for inside if -->
<!-- in -->
<t-if var="show"><t-for item in items><t-var name="item.name" />,</t-for></t-if>
<!-- context -->
{"data": {"show": "true", "items": [{"name": "A"}, {"name": "B"}]}}
<!-- out -->
A,B,

<!-- test: if inside for -->
<!-- in -->
<t-for item in items><t-if var="item.active"><t-var name="item.name" />,</t-if></t-for>
<!-- context -->
{"data": {"items": [{"name": "A", "active": "yes"}, {"name": "B"}, {"name": "C", "active": "yes"}]}}
<!-- out -->
A,C,

<!-- test: nested for loops -->
<!-- in -->
<t-for group in groups>[<t-for item in items><t-var name="group.label" />:<t-var name="item.val" /> </t-for>]</t-for>
<!-- context -->
{"data": {"groups": [{"label": "X"}], "items": [{"val": "1"}, {"val": "2"}]}}
<!-- out -->
[X:1 X:2 ]

<!-- test: include inside for -->
<!-- in:tag.html -->
[<t-attr name="label" />]
<!-- in -->
<t-for item in items><t-include template="tag.html" label="tag" /></t-for>
<!-- context -->
{"data": {"items": [{"name": "A"}, {"name": "B"}]}}
<!-- out -->
[tag][tag]

<!-- test: for inside include -->
<!-- in:list.html -->
<ul><t-for item in items><li><t-var name="item.name" /></li></t-for></ul>
<!-- in -->
<t-include template="list.html" />
<!-- context -->
{"data": {"items": [{"name": "First"}, {"name": "Second"}]}}
<!-- out -->
<ul><li>First</li><li>Second</li></ul>

<!-- test: if inside extend slot -->
<!-- in:base.html -->
<div><t-slot /></div>
<!-- in -->
<t-extend template="base.html">
<t-define name=""><t-if var="x">yes<t-else />no</t-if></t-define>
<!-- context -->
{"data": {"x": "1"}}
<!-- out -->
<div>yes</div>

<!-- test: let then use in for -->
<!-- in -->
<t-let name="prefix">item</t-let><t-for x in items><t-var name="prefix" />:<t-var name="x.v" />,</t-for>
<!-- context -->
{"data": {"items": [{"v": "1"}, {"v": "2"}]}}
<!-- out -->
item:1,item:2,

<!-- test: comment inside if does not break -->
<!-- in -->
<t-if var="x">before<t-comment>hidden</t-comment>after</t-if>
<!-- context -->
{"data": {"x": "yes"}}
<!-- out -->
beforeafter

<!-- test: deeply nested conditionals -->
<!-- in -->
<t-if var="a"><t-if var="b"><t-if var="c">deep</t-if></t-if></t-if>
<!-- context -->
{"data": {"a": "1", "b": "2", "c": "3"}}
<!-- out -->
deep

<!-- test: var with transform inside for -->
<!-- in -->
<t-for item in items><t-var name="item.name" transform="upper" />,</t-for>
<!-- context -->
{"data": {"items": [{"name": "hello"}, {"name": "world"}]}}
<!-- out -->
HELLO,WORLD,

<!-- test: triple nested for loops -->
<!-- in -->
<t-for a in as><t-for b in bs><t-for c in cs><t-var name="a.v" /><t-var name="b.v" /><t-var name="c.v" />,</t-for></t-for></t-for>
<!-- context -->
{"data": {"as": [{"v": "1"}], "bs": [{"v": "2"}], "cs": [{"v": "3"}, {"v": "4"}]}}
<!-- out -->
123,124,

<!-- test: for-if-include nesting -->
<!-- in:tag.html -->
[<t-attr name="label" />]
<!-- in -->
<t-for item in items><t-if var="item.active"><t-include template="tag.html" label="active" /></t-if></t-for>
<!-- context -->
{"data": {"items": [{"active": "yes"}, {}, {"active": "yes"}]}}
<!-- out -->
[active][active]

<!-- test: extend with for and if -->
<!-- in:base.html -->
<main><t-slot /></main>
<!-- in -->
<t-extend template="base.html">
<t-define name=""><t-for item in items><t-if var="item.show"><t-var name="item.name" />,</t-if></t-for></t-define>
<!-- context -->
{"data": {"items": [{"name": "A", "show": "1"}, {"name": "B"}, {"name": "C", "show": "1"}]}}
<!-- out -->
<main>A,C,</main>

<!-- test: include with let and for -->
<!-- in:comp.html -->
<t-let name="prefix">item</t-let><t-for x in items><t-var name="prefix" />:<t-var name="x.name" />,</t-for>
<!-- in -->
<t-include template="comp.html" />
<!-- context -->
{"data": {"items": [{"name": "A"}, {"name": "B"}]}}
<!-- out -->
item:A,item:B,

<!-- test: deeply nested conditionals with else -->
<!-- in -->
<t-if var="a"><t-if var="b"><t-if var="c">abc<t-else />ab</t-if><t-else />a</t-if><t-else />none</t-if>
<!-- context -->
{"data": {"a": "1", "b": "1"}}
<!-- out -->
ab

<!-- test: loop with include with conditional -->
<!-- in:badge.html -->
<t-if attr="type" equals="special"><strong><t-attr name="label" /></strong><t-else /><span><t-attr name="label" /></span></t-if>
<!-- in -->
<t-for item in items><t-include template="badge.html" type="special" label="tag" /></t-for>
<!-- context -->
{"data": {"items": [{"x": "1"}, {"x": "2"}]}}
<!-- out -->
<strong>tag</strong><strong>tag</strong>
