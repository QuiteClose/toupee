<!-- test: for inside if -->
<!-- in -->
<t-if var="show"><t-for item in items><t-var name="item.name" />,</t-for></t-if>
<!-- context -->
{"vars": {"show": "true"}, "collections": {"items": [{"name": "A"}, {"name": "B"}]}}
<!-- out -->
A,B,

<!-- test: if inside for -->
<!-- in -->
<t-for item in items><t-if var="item.active"><t-var name="item.name" />,</t-if></t-for>
<!-- context -->
{"collections": {"items": [{"name": "A", "active": "yes"}, {"name": "B"}, {"name": "C", "active": "yes"}]}}
<!-- out -->
A,C,

<!-- test: nested for loops -->
<!-- in -->
<t-for group in groups>[<t-for item in items><t-var name="group.label" />:<t-var name="item.val" /> </t-for>]</t-for>
<!-- context -->
{"collections": {"groups": [{"label": "X"}], "items": [{"val": "1"}, {"val": "2"}]}}
<!-- out -->
[X:1 X:2 ]

<!-- test: include inside for -->
<!-- in:tag.html -->
[<t-attr name="label" />]
<!-- in -->
<t-for item in items><t-include template="tag.html" label="tag" /></t-for>
<!-- context -->
{"collections": {"items": [{"name": "A"}, {"name": "B"}]}}
<!-- out -->
[tag][tag]

<!-- test: for inside include -->
<!-- in:list.html -->
<ul><t-for item in items><li><t-var name="item.name" /></li></t-for></ul>
<!-- in -->
<t-include template="list.html" />
<!-- context -->
{"collections": {"items": [{"name": "First"}, {"name": "Second"}]}}
<!-- out -->
<ul><li>First</li><li>Second</li></ul>

<!-- test: if inside extend slot -->
<!-- in:base.html -->
<div><t-slot /></div>
<!-- in -->
<t-extend template="base.html">
<t-define name=""><t-if var="x">yes<t-else />no</t-if></t-define>
<!-- context -->
{"vars": {"x": "1"}}
<!-- out -->
<div>yes</div>

<!-- test: let then use in for -->
<!-- in -->
<t-let name="prefix">item</t-let><t-for x in items><t-var name="prefix" />:<t-var name="x.v" />,</t-for>
<!-- context -->
{"collections": {"items": [{"v": "1"}, {"v": "2"}]}}
<!-- out -->
item:1,item:2,

<!-- test: comment inside if does not break -->
<!-- in -->
<t-if var="x">before<t-comment>hidden</t-comment>after</t-if>
<!-- context -->
{"vars": {"x": "yes"}}
<!-- out -->
beforeafter

<!-- test: deeply nested conditionals -->
<!-- in -->
<t-if var="a"><t-if var="b"><t-if var="c">deep</t-if></t-if></t-if>
<!-- context -->
{"vars": {"a": "1", "b": "2", "c": "3"}}
<!-- out -->
deep

<!-- test: var with transform inside for -->
<!-- in -->
<t-for item in items><t-var name="item.name" transform="upper" />,</t-for>
<!-- context -->
{"collections": {"items": [{"name": "hello"}, {"name": "world"}]}}
<!-- out -->
HELLO,WORLD,
