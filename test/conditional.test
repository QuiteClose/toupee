<!-- test: if var exists - true -->
<!-- in -->
<t-if var="x">yes</t-if>
<!-- context -->
{"data": {"x": "hello"}}
<!-- out -->
yes

<!-- test: if var exists - false -->
<!-- in -->
<t-if var="x">yes</t-if>
<!-- out -->

<!-- test: if var exists with empty string - strict true -->
<!-- in -->
<t-if var="x">yes</t-if>
<!-- context -->
{"data": {"x": ""}}
<!-- out -->
yes

<!-- test: if var equals - true -->
<!-- in -->
<t-if var="x" equals="hello">match</t-if>
<!-- context -->
{"data": {"x": "hello"}}
<!-- out -->
match

<!-- test: if var equals - false -->
<!-- in -->
<t-if var="x" equals="hello">match</t-if>
<!-- context -->
{"data": {"x": "world"}}
<!-- out -->

<!-- test: if var not-equals - true -->
<!-- in -->
<t-if var="x" not-equals="hello">different</t-if>
<!-- context -->
{"data": {"x": "world"}}
<!-- out -->
different

<!-- test: if var not-equals - false -->
<!-- in -->
<t-if var="x" not-equals="hello">different</t-if>
<!-- context -->
{"data": {"x": "hello"}}
<!-- out -->

<!-- test: if var not-equals missing is true -->
<!-- in -->
<t-if var="x" not-equals="hello">different</t-if>
<!-- out -->
different

<!-- test: if var not-exists - true when missing -->
<!-- in -->
<t-if var="x" not-exists>missing</t-if>
<!-- out -->
missing

<!-- test: if var not-exists - false when present -->
<!-- in -->
<t-if var="x" not-exists>missing</t-if>
<!-- context -->
{"data": {"x": "hello"}}
<!-- out -->

<!-- test: if var not-exists with empty string - strict false -->
<!-- in -->
<t-if var="x" not-exists>missing</t-if>
<!-- context -->
{"data": {"x": ""}}
<!-- out -->

<!-- test: if-else -->
<!-- in -->
<t-if var="x">yes<t-else />no</t-if>
<!-- out -->
no

<!-- test: if-else with true condition -->
<!-- in -->
<t-if var="x">yes<t-else />no</t-if>
<!-- context -->
{"data": {"x": "1"}}
<!-- out -->
yes

<!-- test: if-elif-else -->
<!-- in -->
<t-if var="a">A<t-elif var="b" />B<t-else />C</t-if>
<!-- context -->
{"data": {"b": "yes"}}
<!-- out -->
B

<!-- test: if-elif-else fallthrough -->
<!-- in -->
<t-if var="a">A<t-elif var="b" />B<t-else />C</t-if>
<!-- out -->
C

<!-- test: if attr exists -->
<!-- in:comp.html -->
<t-if attr="variant">styled<t-else />plain</t-if>
<!-- in -->
<t-include template="comp.html" variant="primary" />
<!-- context -->
<!-- out -->
styled

<!-- test: if attr missing -->
<!-- in:comp.html -->
<t-if attr="variant">styled<t-else />plain</t-if>
<!-- in -->
<t-include template="comp.html" />
<!-- context -->
<!-- out -->
plain

<!-- test: if slot exists -->
<!-- in:layout.html -->
<t-if slot="sidebar">has-sidebar</t-if>
<!-- in -->
<t-extend template="layout.html">
<t-define name="sidebar">content</t-define>
<!-- context -->
<!-- out -->
has-sidebar

<!-- test: if slot not-exists -->
<!-- in:layout.html -->
<t-if slot="sidebar" not-exists>no-sidebar</t-if>
<!-- in -->
<t-extend template="layout.html">
<t-define name="">main</t-define>
<!-- context -->
<!-- out -->
no-sidebar

<!-- test: nested if -->
<!-- in -->
<t-if var="a"><t-if var="b">both</t-if></t-if>
<!-- context -->
{"data": {"a": "1", "b": "2"}}
<!-- out -->
both

<!-- test: orphan else is error -->
<!-- in -->
<t-else />
<!-- error: MalformedElement -->

<!-- test: orphan elif is error -->
<!-- in -->
<t-elif var="x" />
<!-- error: MalformedElement -->

<!-- test: if with boolean true -->
<!-- in -->
<t-if var="flag">yes</t-if>
<!-- context -->
{"data": {"flag": true}}
<!-- out -->
yes

<!-- test: if with boolean false still exists -->
<!-- in -->
<t-if var="flag">exists<t-else />missing</t-if>
<!-- context -->
{"data": {"flag": false}}
<!-- out -->
exists

<!-- test: if with boolean true -->
<!-- in -->
<t-if var="flag">exists</t-if>
<!-- context -->
{"data": {"flag": true}}
<!-- out -->
exists

<!-- test: if with dotted path -->
<!-- in -->
<t-if var="page.active">active</t-if>
<!-- context -->
{"data": {"page": {"active": "yes"}}}
<!-- out -->
active

<!-- test: if with dotted path missing -->
<!-- in -->
<t-if var="page.active">active<t-else />inactive</t-if>
<!-- context -->
{"data": {"page": {}}}
<!-- out -->
inactive

<!-- test: multiple elif branches -->
<!-- in -->
<t-if var="a">A<t-elif var="b" />B<t-elif var="c" />C<t-elif var="d" />D<t-else />none</t-if>
<!-- context -->
{"data": {"c": "yes"}}
<!-- out -->
C

<!-- test: multiple elif all false -->
<!-- in -->
<t-if var="a">A<t-elif var="b" />B<t-elif var="c" />C<t-else />none</t-if>
<!-- out -->
none

<!-- test: if equals with dotted path -->
<!-- in -->
<t-if var="page.type" equals="post">blog<t-else />page</t-if>
<!-- context -->
{"data": {"page": {"type": "post"}}}
<!-- out -->
blog

<!-- test: nested if-else combination -->
<!-- in -->
<t-if var="a"><t-if var="b">both<t-else />only-a</t-if><t-else />neither</t-if>
<!-- context -->
{"data": {"a": "1"}}
<!-- out -->
only-a

<!-- test: if with content between branches -->
<!-- in -->
<t-if var="x">before<t-else />after</t-if>
<!-- context -->
{"data": {"x": "yes"}}
<!-- out -->
before
