<!-- test: basic raw output -->
<!-- in -->
<p><t-raw name="content" /></p>
<!-- context -->
{"data": {"content": "Hello"}}
<!-- out -->
<p>Hello</p>

<!-- test: raw does not escape html -->
<!-- in -->
<t-raw name="content" />
<!-- context -->
{"data": {"content": "<b>bold</b>"}}
<!-- out -->
<b>bold</b>

<!-- test: raw does not escape entities -->
<!-- in -->
<t-raw name="v" />
<!-- context -->
{"data": {"v": "Tom & Jerry <\"quotes\">"}}
<!-- out -->
Tom & Jerry <"quotes">

<!-- test: raw missing is error -->
<!-- in -->
<t-raw name="missing" />
<!-- error: UndefinedVariable -->

<!-- test: raw with default body -->
<!-- in -->
<t-raw name="missing"><em>fallback</em></t-raw>
<!-- out -->
<em>fallback</em>

<!-- test: raw default not used when exists -->
<!-- in -->
<t-raw name="x"><em>fallback</em></t-raw>
<!-- context -->
{"data": {"x": "<strong>real</strong>"}}
<!-- out -->
<strong>real</strong>

<!-- test: raw with empty string value -->
<!-- in -->
[<t-raw name="x" />]
<!-- context -->
{"data": {"x": ""}}
<!-- out -->
[]

<!-- test: raw missing name is error -->
<!-- in -->
<t-raw />
<!-- error: MalformedElement -->

<!-- test: raw unclosed block is error -->
<!-- in -->
<t-raw name="x">no close
<!-- error: MalformedElement -->

<!-- test: raw with dotted path -->
<!-- in -->
<t-raw name="page.content" />
<!-- context -->
{"data": {"page": {"content": "<p>Hello</p>"}}}
<!-- out -->
<p>Hello</p>

<!-- test: raw with transform -->
<!-- in -->
<t-raw name="x" transform="upper" />
<!-- context -->
{"data": {"x": "<b>bold</b>"}}
<!-- out -->
<B>BOLD</B>

<!-- test: raw with chained transforms -->
<!-- in -->
<t-raw name="x" transform="trim|upper" />
<!-- context -->
{"data": {"x": "  hello  "}}
<!-- out -->
HELLO

<!-- test: raw with deeply nested path -->
<!-- in -->
<t-raw name="a.b.c" />
<!-- context -->
{"data": {"a": {"b": {"c": "<em>deep</em>"}}}}
<!-- out -->
<em>deep</em>
