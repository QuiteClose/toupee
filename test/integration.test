<!-- test: blog page with layout -->
<!-- in:base.html -->
<html><head><title><t-var name="site.title" /></title></head><body><t-slot /></body></html>
<!-- in -->
<t-extend template="base.html">
<t-define name="">
<h1><t-var name="page.title" /></h1>
<t-for post in posts><article><h2><t-var name="post.title" /></h2></article></t-for>
</t-define>
<!-- context -->
{"data": {"site": {"title": "My Blog"}, "page": {"title": "Home"}, "posts": [{"title": "First Post"}, {"title": "Second Post"}]}}
<!-- out -->
<html><head><title>My Blog</title></head><body><h1>Home</h1>
<article><h2>First Post</h2></article><article><h2>Second Post</h2></article></body></html>

<!-- test: component composition with include -->
<!-- in:nav.html -->
<nav><t-attr name="label" /></nav>
<!-- in:header.html -->
<header><t-include template="nav.html" label="Main Nav" /></header>
<!-- in -->
<t-include template="header.html" />
<!-- context -->
<!-- out -->
<header><nav>Main Nav</nav></header>

<!-- test: conditional rendering in layout -->
<!-- in:base.html -->
<div><t-if var="show_sidebar"><aside>Sidebar</aside></t-if><main><t-slot /></main></div>
<!-- in -->
<t-extend template="base.html">
<t-define name="">Content here</t-define>
<!-- context -->
{"data": {"show_sidebar": "yes"}}
<!-- out -->
<div><aside>Sidebar</aside><main>Content here</main></div>

<!-- test: conditional rendering hidden -->
<!-- in:base.html -->
<div><t-if var="show_sidebar"><aside>Sidebar</aside></t-if><main><t-slot /></main></div>
<!-- in -->
<t-extend template="base.html">
<t-define name="">Content here</t-define>
<!-- context -->
<!-- out -->
<div><main>Content here</main></div>

<!-- test: let with transform in layout -->
<!-- in -->
<t-let name="slug" transform="slugify"><t-var name="page.title" /></t-let><a href="/<t-var name="slug" />"><t-var name="page.title" /></a>
<!-- context -->
{"data": {"page": {"title": "Hello World"}}}
<!-- out -->
<a href="/hello-world">Hello World</a>

<!-- test: for with all modifiers -->
<!-- in -->
<t-for item in items sort="name" order="desc" offset="1" limit="2" as loop><t-var name="loop.number" />:<t-var name="item.name" />,</t-for>
<!-- context -->
{"data": {"items": [{"name": "apple"}, {"name": "banana"}, {"name": "cherry"}, {"name": "date"}]}}
<!-- out -->
1:cherry,2:banana,

<!-- test: empty page renders plain html -->
<!-- in -->
<html><body><p>No template elements</p></body></html>
<!-- out -->
<html><body><p>No template elements</p></body></html>

<!-- test: raw html injection in slot -->
<!-- in:base.html -->
<div><t-slot /></div>
<!-- in -->
<t-extend template="base.html">
<t-define name=""><t-raw name="content" /></t-define>
<!-- context -->
{"data": {"content": "<p>Rich <em>content</em></p>"}}
<!-- out -->
<div><p>Rich <em>content</em></p></div>

<!-- test: full page with header nav content footer -->
<!-- in:base.html -->
<html><head><title><t-var name="site.title" /></title></head><body><header><t-slot name="header" /></header><main><t-slot /></main><footer><t-slot name="footer" /></footer></body></html>
<!-- in -->
<t-extend template="base.html">
<t-define name="header"><nav><t-for link in nav><a><t-var name="link.label" /></a></t-for></nav></t-define>
<t-define name=""><h1><t-var name="page.title" /></h1><t-raw name="page.body" /></t-define>
<t-define name="footer"><p>&copy; <t-var name="site.title" /></p></t-define>
<!-- context -->
{"data": {"site": {"title": "MySite"}, "page": {"title": "Home", "body": "<p>Welcome</p>"}, "nav": [{"label": "Home"}, {"label": "About"}]}}
<!-- out -->
<html><head><title>MySite</title></head><body><header><nav><a>Home</a><a>About</a></nav></header><main><h1>Home</h1><p>Welcome</p></main><footer><p>&copy; MySite</p></footer></body></html>

<!-- test: card grid with loops -->
<!-- in:card.html -->
<div class="card"><h2><t-attr name="title" /></h2><t-slot /></div>
<!-- in -->
<t-for post in posts><t-include template="card.html" title="Post"><p><t-var name="post.summary" /></p></t-include></t-for>
<!-- context -->
{"data": {"posts": [{"summary": "First post"}, {"summary": "Second post"}]}}
<!-- out -->
<div class="card"><h2>Post</h2><p>First post</p></div><div class="card"><h2>Post</h2><p>Second post</p></div>

<!-- test: nav with conditional active state -->
<!-- in:nav-item.html -->
<a t-attr:class="class"><t-attr name="label" /></a>
<!-- in -->
<nav><t-for link in nav><t-if var="link.active"><t-include template="nav-item.html" label="Active" class="active" /><t-else /><t-include template="nav-item.html" label="Normal" class="link" /></t-if></t-for></nav>
<!-- context -->
{"data": {"nav": [{"active": "yes"}, {}, {"active": "yes"}]}}
<!-- out -->
<nav><a class="active">Active</a><a class="link">Normal</a><a class="active">Active</a></nav>

<!-- test: computed variable used multiple times -->
<!-- in -->
<t-let name="slug" transform="slugify"><t-var name="title" /></t-let><a href="/<t-var name="slug" />/"><t-var name="title" /></a> (<t-var name="slug" />)
<!-- context -->
{"data": {"title": "My Blog Post"}}
<!-- out -->
<a href="/my-blog-post/">My Blog Post</a> (my-blog-post)

<!-- test: many sequential elements -->
<!-- in -->
<t-var name="a" /><t-var name="b" /><t-var name="c" /><t-var name="d" /><t-var name="e" />
<!-- context -->
{"data": {"a": "1", "b": "2", "c": "3", "d": "4", "e": "5"}}
<!-- out -->
12345

<!-- test: nested include with attrs passing through -->
<!-- in:inner.html -->
<span t-attr:class="type"><t-attr name="label" /></span>
<!-- in:outer.html -->
<div><t-include template="inner.html" type="badge" label="Hello" /></div>
<!-- in -->
<t-include template="outer.html" />
<!-- context -->
<!-- out -->
<div><span class="badge">Hello</span></div>

<!-- test: mixed escaping in realistic template -->
<!-- in -->
<a href="/search?q=<t-var name="query" />" title="Search for <t-var name="query" />"><t-var name="query" /></a>
<!-- context -->
{"data": {"query": "Tom & Jerry"}}
<!-- out -->
<a href="/search?q=Tom &amp; Jerry" title="Search for Tom &amp; Jerry">Tom &amp; Jerry</a>
